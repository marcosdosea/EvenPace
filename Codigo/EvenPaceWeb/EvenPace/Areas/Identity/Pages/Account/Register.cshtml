@page
@model RegisterModel
@{
    ViewData["Title"] = "Cadastro Inicial - EvenPace";
    Layout = null;
}

<!doctype html>
<html lang="pt-br">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        .gradient-custom {
            background: linear-gradient(180deg, #FFD700 0%, #FFD700 60%, #111111 100%);
            min-height: 100vh;
        }

        .evenpace-input {
            background-color: #2b2b2b !important;
            border: 1px solid #444 !important;
            color: #ffffff !important;
        }

            .evenpace-input:focus {
                border-color: #FFD700 !important;
                box-shadow: 0 0 0 0.25rem rgba(255, 215, 0, 0.25) !important;
            }

        .evenpace-label {
            color: #999 !important;
        }

        .form-floating > .evenpace-input:focus ~ .evenpace-label,
        .form-floating > .evenpace-input:not(:placeholder-shown) ~ .evenpace-label {
            color: #FFD700 !important;
        }

        .evenpace-link {
            color: #FFD700;
            text-decoration: none;
            transition: color 0.2s ease;
        }

            .evenpace-link:hover {
                color: #e0a800;
                text-decoration: underline;
            }
    </style>
</head>

<body>

    <section class="gradient-custom d-flex align-items-center py-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-md-8 col-lg-6 col-xl-5">
                    <div class="card bg-dark text-white shadow-lg" style="border-radius: 1rem;">
                        <div class="card-body p-4 p-md-5">

                            <div class="text-center mb-4">
                                <h2 class="fw-bold text-uppercase text-light">Cadastro <span style="color: #FFD700;">EvenPace</span></h2>
                                <p class="text-white-50 small mb-0">Insira as informações básicas para iniciar o seu perfil</p>
                            </div>

                            <form id="registerForm" method="post">
                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small" role="alert"></div>

                                <div class="form-floating mb-3">
                                    <input asp-for="Input.Cpf" class="form-control evenpace-input" aria-required="true" placeholder="000.000.000-00" />
                                    <label asp-for="Input.Cpf" class="evenpace-label">CPF</label>
                                    <span asp-validation-for="Input.Cpf" class="text-danger small"></span>
                                </div>

                                <div class="form-floating mb-3">
                                    <input asp-for="Input.Email" class="form-control evenpace-input" autocomplete="username" aria-required="true" placeholder="nome@exemplo.com" />
                                    <label asp-for="Input.Email" class="evenpace-label">E-mail</label>
                                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                                </div>

                                <div class="form-floating mb-3">
                                    <input asp-for="Input.Password" class="form-control evenpace-input" autocomplete="new-password" aria-required="true" placeholder="Senha" />
                                    <label asp-for="Input.Password" class="evenpace-label">Senha</label>
                                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                                </div>

                                <div class="form-floating mb-4">
                                    <input asp-for="Input.ConfirmPassword" class="form-control evenpace-input" autocomplete="new-password" aria-required="true" placeholder="Confirmar Senha" />
                                    <label asp-for="Input.ConfirmPassword" class="evenpace-label">Confirmar Senha</label>
                                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                                </div>

                                <div class="d-grid gap-2 mb-2">
                                    <button id="registerSubmit" type="submit" class="btn btn-outline-light btn-lg fw-bold">
                                        Avançar Cadastro
                                    </button>
                                </div>
                            </form>

                            <div class="text-center border-top border-secondary mt-4 pt-3">
                                <p class="text-white-50 small m-0">
                                    Já possui uma conta?
                                    <a href="/Identity/Account/Login" class="evenpace-link fw-bold">Faça Login aqui</a>
                                </p>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />

</body>
</html>