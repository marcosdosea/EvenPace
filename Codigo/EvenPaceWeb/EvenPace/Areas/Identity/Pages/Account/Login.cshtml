@page
@model LoginModel

@{
    ViewData["Title"] = "Entrar";
    Layout = null; // Removido para usar o design de tela cheia
}

<!doctype html>
<html lang="pt-br">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>EvenPace - Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        .gradient-custom {
            background: linear-gradient(180deg, #FFD700 0%, #FFD700 60%, #111111 100%);
            min-height: 100vh;
        }

        .evenpace-bg-dark {
            background-color: #1a1a1a !important;
            border: 2px solid #333;
            border-radius: 15px;
        }

        .evenpace-text-yellow {
            color: #FFC107 !important;
        }

        .evenpace-btn-yellow {
            background-color: #FFC107;
            color: #000000;
            font-weight: 700;
            border: none;
            transition: all 0.3s ease;
        }

            .evenpace-btn-yellow:hover {
                background-color: #e0a800;
                color: #000000;
                transform: translateY(-1px);
                box-shadow: 0 4px 12px rgba(255, 193, 7, 0.3);
            }

        .evenpace-input {
            background-color: #2b2b2b !important;
            border: 1px solid #444 !important;
            color: #ffffff !important;
        }

            .evenpace-input:focus {
                border-color: #FFC107 !important;
                box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.25) !important;
            }

        .evenpace-label {
            color: #aaa !important;
        }

        .form-floating > .evenpace-input:focus ~ .evenpace-label,
        .form-floating > .evenpace-input:not(:placeholder-shown) ~ .evenpace-label {
            color: #FFC107 !important;
        }

        .evenpace-link {
            color: #FFC107;
            text-decoration: none;
            transition: color 0.2s ease;
        }

            .evenpace-link:hover {
                color: #e0a800;
                text-decoration: underline;
            }
    </style>
</head>

<body class="gradient-custom">

    <div class="container py-5">
        <div class="row justify-content-center align-items-center vh-100">
            <div class="col-12 col-md-8 col-lg-6 col-xl-5">
                <div class="card shadow-lg evenpace-bg-dark p-4">
                    <div class="card-body">
                        <div class="text-center mb-4">
                            <h2 class="fw-bold text-light text-uppercase">Acessar <span class="evenpace-text-yellow">EvenPace</span></h2>
                            <p class="text-muted small">Insira suas credenciais para acessar a plataforma</p>
                        </div>

                        <form id="account" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small" role="alert"></div>

                            <div class="form-floating mb-3">
                                <input asp-for="Input.Email" class="form-control evenpace-input" autocomplete="username" aria-required="true" placeholder="Email" />
                                <label asp-for="Input.Email" class="evenpace-label">E-mail</label>
                                <span asp-validation-for="Input.Email" class="text-danger small"></span>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="Input.Password" class="form-control evenpace-input" autocomplete="current-password" aria-required="true" placeholder="Senha" />
                                <label asp-for="Input.Password" class="evenpace-label">Senha</label>
                                <span asp-validation-for="Input.Password" class="text-danger small"></span>
                            </div>

                            <div class="checkbox mb-3 d-flex justify-content-between align-items-center">
                                <label asp-for="Input.RememberMe" class="form-label text-light small m-0">
                                    <input class="form-check-input me-1" asp-for="Input.RememberMe" style="accent-color: #FFC107;" />
                                    Lembrar de mim?
                                </label>
                                <a id="forgot-password" asp-page="./ForgotPassword" class="evenpace-link small">Esqueceu a senha?</a>
                            </div>

                            <button id="login-submit" type="submit" class="w-100 btn btn-lg evenpace-btn-yellow my-2 shadow-sm">Entrar</button>
                        </form>

                        <div class="text-center mt-4 border-top border-secondary pt-3">
                            <p class="text-light small m-0">
                                Ainda não possui conta?
                                <a href="/Identity/Account/Register" class="evenpace-link fw-bold">Cadastre-se aqui</a>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />

</body>
</html>