@{
    ViewData["Title"] = "Entrar";
    Layout = "_Layout";
}

<section class="container-fluid px-3 px-lg-5 py-5 py-lg-6">
    <div class="mx-auto" style="max-width: 1180px;">
        <div class="rounded-5 border p-4 p-lg-5" style="background: linear-gradient(180deg, #fffdf6 0%, #ffffff 100%); border-color: #f1e2b6 !important;">
            <div class="row align-items-center g-4">
                <div class="col-12 col-lg-7">
                    <span class="d-inline-flex align-items-center gap-2 rounded-pill px-3 py-2 mb-3" style="background:#fff4cf;color:#7b5d12;font-weight:800;border:1px solid #f1e2b6;">
                        Acesso EvenPace
                    </span>
                    <h1 class="display-5 fw-bold mb-3" style="letter-spacing:-0.03em;">
                        Escolha como entrar na plataforma.
                    </h1>
                    <p class="fs-5 text-secondary mb-0" style="max-width: 36rem;">
                        Se você corre, entre como corredor. Se você organiza eventos, acesse como organização para criar e gerenciar suas corridas.
                    </p>
                </div>

                <div class="col-12 col-lg-5">
                    <div class="d-grid gap-3">
                        <a class="btn btn-lg rounded-pill py-3 fw-bold" href="@Url.Action("Login", "Corredor")" style="background:linear-gradient(135deg,#ffe7a6,#f7cf66);border:1px solid #f0d07e;color:#443200;">
                            Entrar como corredor
                        </a>
                        <a class="btn btn-lg rounded-pill py-3 fw-bold" href="@Url.Action("Login", "Organizacao")" style="background:#fff4cf;border:1px solid #f1e2b6;color:#6e5410;">
                            Entrar como organização
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
