@{
    ViewData["Title"] = "Página Inicial";
}

<style>
    .evenpace-bg-dark {
        background-color: #1a1a1a !important; /* Preto suave para os cards */
    }

    .evenpace-text-yellow {
        color: #FFC107 !important; /* Amarelo clássico */
    }

    .evenpace-btn-yellow {
        background-color: #FFC107;
        color: #000000;
        font-weight: 800;
        border: none;
        transition: all 0.3s ease;
    }

        .evenpace-btn-yellow:hover {
            background-color: #e0a800;
            color: #000000;
            transform: translateY(-2px); /* Efeito de flutuar ao passar o mouse */
            box-shadow: 0 4px 8px rgba(255, 193, 7, 0.4);
        }

    .evenpace-card {
        border-radius: 15px;
        border: 2px solid #333;
    }

    .evenpace-link {
        color: #b38600;
        transition: color 0.3s ease;
    }

        .evenpace-link:hover {
            color: #FFC107;
        }
</style>

<div class="text-center mt-5">
    <h1 class="display-4 fw-bold text-dark mb-2">
        Bem-vindo ao <span class="evenpace-text-yellow" style="text-shadow: 1px 1px 2px rgba(0,0,0,0.8);">EvenPace</span>
    </h1>
    <p class="lead mb-5 text-secondary fw-semibold">A plataforma definitiva para organizar e dominar suas corridas.</p>

    <div class="row justify-content-center">
        <div class="col-md-5 mb-4">
            <div class="card shadow-lg h-100 evenpace-bg-dark evenpace-card">
                <div class="card-body d-flex flex-column justify-content-center py-5 px-4">
                    <h3 class="card-title evenpace-text-yellow mb-3 fw-bold">Sou uma Organização</h3>
                    <p class="card-text text-light mb-4">
                        Crie e gerencie seus eventos, controle a venda de ingressos, organize a distribuição de kits e acompanhe todos os resultados em tempo real.
                    </p>
                    <div class="mt-auto">
                        <a href="/Identity/Account/Login" class="btn btn-lg w-100 evenpace-btn-yellow shadow-sm">
                            Entrar como Organização
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-5 mb-4">
            <div class="card shadow-lg h-100 evenpace-bg-dark evenpace-card">
                <div class="card-body d-flex flex-column justify-content-center py-5 px-4">
                    <h3 class="card-title evenpace-text-yellow mb-3 fw-bold">Sou um Corredor</h3>
                    <p class="card-text text-light mb-4">
                        Inscreva-se nas melhores corridas, acompanhe seu histórico de desempenho, resgate cupons exclusivos e avalie os eventos.
                    </p>
                    <div class="mt-auto">
                        <a href="/Corredor/Login" class="btn btn-lg w-100 evenpace-btn-yellow shadow-sm">
                            Entrar como Corredor
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>