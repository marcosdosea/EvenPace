@model Models.InscricaoViewModel

@{
	Layout = null;
	var popupMessage = ViewBag.PopupMessage as string;
}

@functions {
	private string ObterImagemEvento(string? imagem)
	{
		if (string.IsNullOrWhiteSpace(imagem))
		{
			return string.Empty;
		}

		if (imagem.StartsWith("http", StringComparison.OrdinalIgnoreCase) || imagem.StartsWith("/", StringComparison.Ordinal))
		{
			return imagem;
		}

		if (imagem.StartsWith("~", StringComparison.Ordinal))
		{
			return Url.Content(imagem);
		}

		if (imagem.Contains("/", StringComparison.Ordinal))
		{
			return Url.Content($"~/imagens/{imagem}");
		}

		return Url.Content($"~/imagens/banner-eventos/{imagem}");
	}
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<title>@Model.NomeEvento</title>
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" />
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800&display=swap" rel="stylesheet" />

	<style>
		:root {
			--surface: #ffffff;
			--surface-soft: #fffdf3;
			--text: #121212;
			--muted: #6f7780;
			--border: #ece7d5;
			--yellow: #ffe07a;
			--yellow-strong: #f4c542;
			--shadow: 0 18px 40px rgba(18, 18, 18, 0.08);
		}

		* { box-sizing: border-box; }

		body {
			margin: 0;
			font-family: "Montserrat", system-ui, sans-serif;
			color: var(--text);
			background: linear-gradient(180deg, #ffffff 0%, #fffef7 100%);
			min-height: 100vh;
		}

		.page-shell {
			min-height: 100vh;
		}

		.page-card {
			min-height: 100vh;
			background: #fff;
		}

		.topbar {
			padding: 18px 18px 14px;
			border-bottom: 1px solid var(--border);
			background: rgba(255, 255, 255, 0.95);
			backdrop-filter: blur(10px);
			position: sticky;
			top: 0;
			z-index: 5;
		}

		.back-link {
			display: inline-flex;
			align-items: center;
			gap: 8px;
			text-decoration: none;
			color: var(--text);
			font-weight: 800;
		}

		.hero {
			padding: 18px 0 22px;
		}

		.hero-box {
			background: linear-gradient(135deg, #fffdf4, #ffffff);
			border: 1px solid var(--border);
			border-radius: 26px;
			box-shadow: var(--shadow);
			overflow: hidden;
		}

		.hero-media {
			position: relative;
			min-height: 250px;
			background: var(--surface-soft);
		}

		.hero-media img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			display: block;
		}

		.hero-fallback {
			min-height: 250px;
			display: grid;
			place-items: center;
			color: var(--muted);
			font-weight: 700;
			text-align: center;
			padding: 24px;
		}

		.hero-content {
			padding: 22px;
		}

		.event-title {
			margin: 0;
			font-size: clamp(1.7rem, 2.4vw, 2.4rem);
			font-weight: 800;
			letter-spacing: -0.04em;
		}

		.meta-row {
			display: flex;
			flex-wrap: wrap;
			gap: 10px;
			margin-top: 16px;
		}

		.meta-pill {
			display: inline-flex;
			align-items: center;
			gap: 8px;
			padding: 10px 14px;
			border-radius: 999px;
			background: rgba(255, 224, 122, 0.22);
			border: 1px solid rgba(244, 197, 66, 0.22);
			font-weight: 700;
			font-size: .86rem;
		}

		.form-shell {
			padding: 0 0 36px;
		}

		.form-card {
			background: #fff;
			border: 1px solid var(--border);
			border-radius: 26px;
			box-shadow: var(--shadow);
			padding: 20px;
		}

		.form-title {
			margin: 0 0 6px;
			font-size: 1.3rem;
			font-weight: 800;
			letter-spacing: -0.02em;
		}

		.form-subtitle {
			margin: 0 0 22px;
			color: var(--muted);
		}

		.field-group {
			margin-bottom: 18px;
		}

		.label-bold {
			display: block;
			margin-bottom: 8px;
			font-size: .85rem;
			letter-spacing: .08em;
			text-transform: uppercase;
			font-weight: 800;
			color: #353535;
		}

		.form-control-evenpace {
			width: 100%;
			border: 1px solid var(--border);
			border-radius: 18px;
			padding: 14px 16px;
			background: #fff;
			outline: none;
			transition: .2s ease;
		}

		.form-control-evenpace:focus {
			border-color: var(--yellow-strong);
			box-shadow: 0 0 0 4px rgba(244, 197, 66, 0.12);
		}

		.textarea-evenpace {
			min-height: 110px;
			resize: vertical;
		}

		.event-row {
			display: grid;
			grid-template-columns: 1fr;
			gap: 12px;
		}

		.event-icon-box {
			display: flex;
			align-items: center;
			gap: 12px;
			padding: 14px 16px;
			border: 1px solid var(--border);
			border-radius: 18px;
			background: var(--surface-soft);
		}

		.event-icon {
			width: 42px;
			height: 42px;
			border-radius: 14px;
			display: grid;
			place-items: center;
			background: rgba(255, 224, 122, 0.32);
		}

		.event-icon strong {
			display: block;
			font-size: .92rem;
		}

		.event-icon small {
			color: var(--muted);
		}

		.section-title {
			margin: 0 0 14px;
			font-size: 1.04rem;
			font-weight: 800;
			letter-spacing: -0.02em;
		}

		.pill-grid {
			display: flex;
			flex-wrap: wrap;
			gap: 12px;
		}

		.choice-label {
			display: inline-flex;
			align-items: center;
			cursor: pointer;
		}

		.choice-label input {
			position: absolute;
			opacity: 0;
			pointer-events: none;
		}

		.choice-pill {
			padding: 12px 18px;
			border-radius: 999px;
			border: 1px solid var(--border);
			background: #fff;
			font-weight: 800;
			transition: .2s ease;
		}

		.choice-label input:checked + .choice-pill {
			background: rgba(255, 224, 122, 0.55);
			border-color: rgba(244, 197, 66, 0.55);
		}

		.choice-label input:focus-visible + .choice-pill {
			box-shadow: 0 0 0 4px rgba(244, 197, 66, 0.12);
		}

		.validation-note {
			display: block;
			margin-top: 8px;
		}

		.payment-note {
			margin: 14px 0 0;
			color: var(--muted);
			font-size: .9rem;
			font-weight: 700;
			line-height: 1.5;
		}

		.swal2-popup {
			border-radius: 1rem;
			border: 1px solid rgba(220, 53, 69, 0.12);
			background: #fff;
			color: #212529;
		}

		.btn-row {
			display: grid;
			grid-template-columns: 1fr;
			gap: 12px;
			margin-top: 24px;
		}

		.btn-submit {
			border: none;
			border-radius: 999px;
			padding: 14px 18px;
			background: linear-gradient(135deg, var(--yellow), var(--yellow-strong));
			color: #222;
			font-weight: 800;
			box-shadow: 0 12px 18px rgba(244, 197, 66, 0.18);
		}

		.btn-secondary-soft {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			padding: 14px 18px;
			border-radius: 999px;
			text-decoration: none;
			background: #fff;
			border: 1px solid var(--border);
			color: var(--text);
			font-weight: 800;
		}

		.alert-stack {
			display: grid;
			gap: 12px;
			margin-bottom: 14px;
		}

		@@media (min-width: 768px) {
			.event-row {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}

			.btn-row {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
		}

		@@media (max-width: 767.98px) {
			.topbar {
				padding: 16px;
			}

			.hero-content,
			.form-card {
				padding: 18px;
			}

			.form-shell {
				padding-bottom: 24px;
			}
		}
	</style>
</head>
<body>
	<div class="page-shell">
		<div class="page-card">
			<div class="topbar">
				<div class="container-fluid px-0">
					<a href="javascript:history.back()" class="back-link">← Voltar</a>
				</div>
			</div>

			<div class="container-fluid px-3 px-md-4 px-xl-5">
				<div class="hero">
					<div class="hero-box">
						<div class="hero-media">
							@if (!string.IsNullOrEmpty(Model.ImagemEvento))
							{
								<img src="@ObterImagemEvento(Model.ImagemEvento)" alt="@Model.NomeEvento" />
							}
							else
							{
								<div class="hero-fallback">Sem imagem do evento</div>
							}
						</div>
						<div class="hero-content">
							<h1 class="event-title">@Model.NomeEvento</h1>
							<div class="meta-row">
								<span class="meta-pill">📍 @Model.Local</span>
								<span class="meta-pill">📅 @Model.DataEvento.ToString("dd/MM/yyyy")</span>
								<span class="meta-pill">💛 Pagamento pelo Mercado Pago</span>
							</div>
						</div>
					</div>
				</div>

				<div class="alert-stack">
					@if (!string.IsNullOrWhiteSpace(popupMessage))
					{
						<div class="swal2-popup shadow-sm p-3 p-md-4 text-center">
							<div class="fw-bold mb-2 text-danger">Não foi possível concluir</div>
							<div>@popupMessage</div>
						</div>
					}
				</div>

				<div class="form-shell">
					<form asp-controller="Inscricao" asp-action="Create" method="post">
						@Html.AntiForgeryToken()
						<input type="hidden" asp-for="IdEvento" />
						<input type="hidden" asp-for="IdKit" />

						<div class="form-card">
							<h2 class="form-title">Inscrição e pagamento</h2>
							<p class="form-subtitle">Selecione o tamanho da camisa e a distância. Ao confirmar, você será redirecionado para concluir o pagamento no Mercado Pago.</p>

							<div class="field-group">
								<label class="label-bold">Tamanho da camisa</label>
								<div class="pill-grid">
									@foreach (var tamanho in new[] { "P", "M", "G", "GG" })
									{
										<label class="choice-label">
											<input type="radio" asp-for="TamanhoCamisa" value="@tamanho" />
											<span class="choice-pill">@tamanho</span>
										</label>
									}
								</div>
								<span asp-validation-for="TamanhoCamisa" class="text-danger small validation-note"></span>
							</div>

							<div class="field-group">
								<label class="label-bold">Escolha a distância</label>
								<div class="pill-grid">
									@foreach (var percurso in Model.Percursos)
									{
										<label class="choice-label">
											<input type="radio" asp-for="Distancia" value="@percurso" />
											<span class="choice-pill">@percurso</span>
										</label>
									}
								</div>
								<span asp-validation-for="Distancia" class="text-danger small validation-note"></span>
							</div>

							<div asp-validation-summary="All" class="text-danger small"></div>

							<div class="btn-row">
								<button type="submit" class="btn-submit">Confirmar e ir para pagamento</button>
								<a asp-controller="Evento" asp-action="IndexUsuario" class="btn-secondary-soft">Voltar para eventos</a>
							</div>
							<p class="payment-note">Sua inscrição ficará pendente até a confirmação do pagamento.</p>
						</div>
					</form>
				</div>
			</div>
		</div>
	</div>
</body>
</html>
