@model Models.InscricaoViewModel

@{
    Layout = null;
}



<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.NomeEvento</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>

    <style>
        body {
            background: #fff;
        }

        .app-card {
            background: #fff;
            border-radius: 1rem;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            height: 85vh;
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15);
        }

        .header {
            padding: 18px;
            border-bottom: 1px solid #eee;
            cursor: pointer;
        }

        .app-content {
            flex: 1;
            overflow-y: auto;
            padding: 16px;
        }

        .image-placeholder {
            width: 100%;
            height: 220px;
            background: #e9ecef;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #6c757d;
            font-weight: bold;
            margin-bottom: 16px;
        }

        h2 {
            font-weight: 700;
            text-align: center;
            margin-bottom: 16px;
            text-transform: uppercase;
        }

        .evento-container {
            display: flex;
            align-items: flex-start;
            margin-bottom: 12px;
        }

        .icon-circle {
            background: #FFD700;
            border-radius: 50%;
            width: 38px;
            height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 12px;
        }

        .opcoes {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 15px;
            margin-bottom: 20px;
        }

        .opcao-label {
            display: flex;
            flex-direction: column;
            align-items: center;
            cursor: pointer;
        }

            .opcao-label input[type="radio"] {
                display: none;
            }

        .opcao {
            padding: 10px 20px;
            background-color: black;
            color: gold;
            border-radius: 5px;
            font-weight: bold;
            text-align: center;
            min-width: 50px;
            transition: 0.2s;
        }

        .opcao-label input[type="radio"]:checked + .opcao {
            background-color: gold;
            color: black;
        }

        .checkmark {
            width: 20px;
            height: 20px;
            border: 2px solid gold;
            border-radius: 3px;
            margin-top: 5px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .opcao-label input[type="radio"]:checked + .opcao + .checkmark::after {
            content: "✓";
            color: black;
            font-weight: bold;
        }

        .btn-confirmar {
            background: #FFD700;
            border: none;
            border-radius: 30px;
            font-weight: bold;
            font-size: 16px;
            padding: 12px;
            width: 100%;
            margin-top: 24px;
        }

            .btn-confirmar:hover {
                background: #f1c40f;
            }

        .bottom-nav {
            height: 70px;
            border-top: 1px solid #ddd;
            display: flex;
            justify-content: space-around;
            align-items: center;
            font-size: 12px;
            background: #fff;
        }

        .opcao-radio {
            position: relative;
            display: inline-block;
            margin: 8px;
            cursor: pointer;
        }

            .opcao-radio .check-icon {
                display: none;
                text-align: center;
                font-size: 18px;
                margin-top: 4px;
                color: #FFD700;
            }

            .opcao-radio input:checked + .opcao + .check-icon {
                display: block;
            }
    </style>
</head>

<body>
    <section class="vh-100 d-flex align-items-center">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-md-8 col-lg-6 col-xl-5">
                    <div class="app-card">
                        <div class="header" onclick="history.back()">← Voltar</div>

                        <form asp-controller="Inscricao" asp-action="Create" method="post" class="app-content">
                            @Html.AntiForgeryToken()

                            <input type="hidden" asp-for="IdEvento" />
                            <input type="hidden" asp-for="IdKit" />

                            @if (!string.IsNullOrEmpty(Model.ImagemEvento))
                            {
                                <img src="@Url.Content($"~/imagens/{Model.ImagemEvento}")"
                                     class="img-fluid mb-3"
                                     style="width:100%; height:220px; object-fit:cover; border-radius:14px;" />
                            }
                            else
                            {
                                <div class="image-placeholder">Sem imagem do evento</div>
                            }

                            <h2>@Model.NomeEvento</h2>

                            <div class="evento-container">
                                <div class="icon-circle">📍</div>
                                <div>
                                    <small>Local</small>
                                    <p><strong>@Model.Local</strong></p>
                                </div>
                            </div>

                            <div class="evento-container">
                                <div class="icon-circle">📅</div>
                                <div>
                                    <small>Data</small>
                                    <p><strong>@Model.DataEvento.ToString("dd/MM/yyyy")</strong></p>
                                </div>
                            </div>

                            <h5 class="text-center mb-3">Tamanho da camisa</h5>
                            <div class="opcoes">
                                @foreach (var tamanho in new[] { "P", "M", "G", "GG" })
                                {
                                    <label class="opcao-label">
                                        <input type="radio" asp-for="TamanhoCamisa" value="@tamanho" />
                                        <div class="opcao">@tamanho</div>
                                        <div class="checkmark"></div>
                                    </label>
                                }
                            </div>

                            <h5 class="text-center mb-3">Escolha a distância</h5>
                            <div class="opcoes">
                                @foreach (var percurso in Model.Percursos)
                                {
                                    <label class="opcao-label">
                                        <input type="radio" asp-for="Distancia" value="@percurso" />
                                        <div class="opcao">@percurso</div>
                                        <div class="checkmark"></div>
                                    </label>
                                }
                            </div>

                            <button type="submit" class="btn-confirmar">Confirmar Inscrição</button>
                        </form>

                        <div class="bottom-nav">
                            <a asp-controller="Evento" asp-action="IndexUsuario">🏠<br />Início</a>
                            <div>🏆<br />Conquistas</div>
                            <div>🎟️<br />Cupons</div>
                            <div>🕓<br />Histórico</div>
                            <div>👤<br />Perfil</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script>
        $(document).ready(function () {
            $('#formInscricao').submit(function (e) {
                e.preventDefault();
                var form = $(this);
                var url = '@Url.Action("Create", "Inscricao")';

                $.ajax({
                    type: "POST",
                    url: url,
                    data: form.serialize(),
                    success: function (response) {
                        $('#mensagem').html('<div class="alert alert-success mt-3">Inscrição realizada com sucesso!</div>');
                    },
                    error: function (xhr) {
                        $('#mensagem').html('<div class="alert alert-danger mt-3">Erro ao salvar inscrição: ' + xhr.responseText + '</div>');
                    }
                });
            });
        });
    </script>
</body>
</html>