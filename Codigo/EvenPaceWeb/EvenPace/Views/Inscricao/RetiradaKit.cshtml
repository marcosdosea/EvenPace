@model IEnumerable<Models.InscricaoViewModel>

@{
    ViewData["Title"] = "Ingressos do Evento";
    var nomeEvento = Model.FirstOrDefault()?.IdEventoNavigation?.Nome ?? "Evento";
}

<style>
    :root {
        --primary-yellow: #ffd700;
        --bg-light: #f8f9fa;
        --gray-card: #e0e0e0;
    }

    main.index-page {
        padding: 20px;
    }

    /* Estilo dos Cards de Resumo */
    .summary-card {
        background-color: var(--gray-card);
        border-radius: 12px;
        padding: 15px 25px;
        flex: 1;
        min-width: 250px;
    }

    .summary-label {
        font-weight: bold;
        font-size: 1.1rem;
        margin-bottom: 0;
    }

    .summary-value {
        font-size: 1.2rem;
        font-weight: bold;
    }

    /* Estilo da Tabela e DataTables */
    .table-container {
        background-color: #d3d3d3;
        border-radius: 15px;
        padding: 20px;
    }

    .evenpace-table {
        background-color: white;
        border-radius: 8px;
        overflow: hidden;
    }

        .evenpace-table thead th {
            background-color: #f0f0f0;
            border-bottom: 1px solid #ccc;
            color: #000;
            font-weight: bold;
        }

    /* Ajuste para a busca do DataTables ficar bonita */
    .dataTables_filter input {
        border-radius: 20px;
        border: 1px solid #ced4da;
        padding: 5px 15px;
        outline: none;
    }

    /* Botões de Check-in */
    .btn-checkin-pending {
        background-color: #808080;
        color: white;
        border-radius: 5px;
        font-size: 0.75rem;
        width: 100px;
        border: none;
        padding: 6px;
        transition: 0.2s;
    }

        .btn-checkin-pending:hover {
            background-color: #666;
        }

    .btn-checkin-done {
        background-color: #28a745;
        color: white;
        border-radius: 5px;
        font-size: 0.75rem;
        width: 100px;
        display: inline-block;
        text-align: center;
        padding: 6px;
    }
</style>

<main class="container-fluid index-page">
    <header class="mb-4">
        <h1 class="fw-bold mb-0">Ingressos</h1>
        <p class="fs-5">@nomeEvento</p>
    </header>

    <section class="d-flex flex-wrap gap-3 mb-5">
        <div class="summary-card d-flex justify-content-between align-items-center shadow-sm">
            <span class="summary-label">Ingressos Aprovados:</span>
            <span class="summary-value" id="qtdAprovados">@Model.Count(i => i.StatusRetiradaKit)</span>
        </div>
        <div class="summary-card d-flex justify-content-between align-items-center shadow-sm">
            <span class="summary-label">Ingressos Cancelados:</span>
            <span class="summary-value">0</span>
        </div>
        <div class="summary-card d-flex justify-content-between align-items-center shadow-sm">
            <span class="summary-label">Ingressos Pendentes:</span>
            <span class="summary-value" id="qtdPendentes">@Model.Count(i => !i.StatusRetiradaKit)</span>
        </div>
    </section>

    @Html.AntiForgeryToken()

    <section class="table-container shadow-sm">
        <div class="table-responsive bg-white rounded-3 p-3">
            <table id="tabelaInscritos" class="table evenpace-table mb-0 w-100">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>CPF</th>
                        <th>Kit</th>
                        <th>Distância</th>
                        <th>Camisa</th>
                        <th class="text-center">Check-in</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.IdCorredorNavigation?.Nome</td>
                            <td>@item.IdCorredorNavigation?.Cpf</td>
                            <td>@item.IdKitNavigation?.Nome</td>
                            <td>@item.Distancia</td>
                            <td>@item.TamanhoCamisa</td>
                            <td class="text-center" id="td-checkin-@item.Id">
                                @if (!item.StatusRetiradaKit)
                                {
                                    <button type="button"
                                            class="btn-checkin-pending btn-checkin"
                                            data-id="@item.Id"
                                            data-evento="@item.IdEvento">
                                        Não Retirado
                                    </button>
                                }
                                else
                                {
                                    <span class="btn-checkin-done">Retirado</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</main>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            // 1. Inicializa o DataTables
            $('#tabelaInscritos').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/pt-BR.json"
                },
                "pageLength": 10,
                "columnDefs": [
                    { "orderable": false, "targets": 5 } // Remove a setinha de ordenação da coluna de botões
                ]
            });

            // 2. Intercepta o clique no botão "Não Retirado" usando AJAX
            // Usamos $(document).on para funcionar mesmo em botões que estão na página 2, 3, etc do DataTables
            $(document).on('click', '.btn-checkin', function () {
                var btn = $(this);
                var idInscricao = btn.data('id');
                var idEvento = btn.data('evento');
                var token = $('input[name="__RequestVerificationToken"]').val();

                // Muda o visual do botão temporariamente para evitar duplo clique
                btn.prop('disabled', true).text('Aguarde...');

                $.ajax({
                    url: '@Url.Action("ConfirmarRetirada", "Inscricao")',
                    type: 'POST',
                    data: {
                        idInscricao: idInscricao,
                        idEvento: idEvento,
                        __RequestVerificationToken: token
                    },
                    success: function (response) {
                        // Se deu certo, troca o botão cinza pelo selo verde
                        var parentTd = btn.closest('td');
                        parentTd.html('<span class="btn-checkin-done">Retirado</span>');

                        // Opcional e muito legal: Atualiza os contadores lá em cima na hora!
                        var qtdPendentes = $('#qtdPendentes');
                        var qtdAprovados = $('#qtdAprovados');

                        qtdPendentes.text(parseInt(qtdPendentes.text()) - 1);
                        qtdAprovados.text(parseInt(qtdAprovados.text()) + 1);
                    },
                    error: function () {
                        alert("Erro ao confirmar a retirada. Tente novamente.");
                        btn.prop('disabled', false).text('Não Retirado');
                    }
                });
            });
        });
    </script>
}