@model IEnumerable<Models.InscricaoViewModel>

@{
    ViewData["Title"] = "Ingressos";
    Layout = "~/Views/Shared/_LayoutOrganizacao.cshtml";

    <link rel="stylesheet" href="~/css/kit.css" />

    var nomeEvento = ViewBag.NomeEvento ?? "Evento";

    var totalInscritos = Model.Count();
    var confirmados = Model.Count(i => string.Equals(i.Status, "Confirmada", StringComparison.OrdinalIgnoreCase));
    var cancelados = Model.Count(i => string.Equals(i.Status, "Cancelada", StringComparison.OrdinalIgnoreCase));
}

<style>

    .summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(220px,1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .summary-card {
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e0e0e0;
        padding: 25px;
        box-shadow: 0 4px 15px rgba(0,0,0,.03);
    }

        .summary-card h2 {
            margin: 0;
            font-size: 32px;
            font-weight: 700;
            color: #222;
        }

        .summary-card span {
            color: #666;
            font-weight: 600;
        }

    .table-container {
        width: 100%;
    }

    .custom-table-wrapper {
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e0e0e0;
        box-shadow: 0 4px 15px rgba(0,0,0,.03);
        overflow: hidden;
    }

    table.dataTable thead th {
        background: #fafafa;
        border-bottom: 1px solid #ececec;
        font-weight: 700;
    }

    .badge-status {
        padding: 6px 12px;
        border-radius: 6px;
        font-size: .85rem;
        font-weight: 700;
    }

    .badge-confirmado {
        background: #d4edda;
        color: #155724;
    }

    .badge-cancelado {
        background: #f8d7da;
        color: #721c24;
    }

    .badge-pendente {
        background: #fff3cd;
        color: #856404;
    }

</style>

<main class="main-container">

    <header class="page-header header-responsive" style="margin-bottom:30px;">
        <div class="header-title-group">
            <div class="header-text">
                <h1>Ingressos</h1>
                <p class="subtitle">@nomeEvento</p>
            </div>
        </div>
    </header>

    <section class="summary-grid">

        <div class="summary-card">
            <h2>@totalInscritos</h2>
            <span>Total de Inscritos</span>
        </div>

        <div class="summary-card">
            <h2>@confirmados</h2>
            <span>Inscrições Confirmadas</span>
        </div>

        <div class="summary-card">
            <h2>@cancelados</h2>
            <span>Canceladas</span>
        </div>

    </section>

    <section class="table-container">

        <div class="custom-table-wrapper">

            <table id="tabelaInscricoes" class="table table-hover align-middle mb-0">

                <thead>

                    <tr>

                        <th>Participante</th>

                        <th>CPF</th>

                        <th>Kit</th>

                        <th>Distância</th>

                        <th>Camisa</th>

                        <th>Status</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>
                                @item.IdCorredorNavigation?.Nome
                            </td>

                            <td>
                                @item.IdCorredorNavigation?.Cpf
                            </td>

                            <td>
                                @item.IdKitNavigation?.Nome
                            </td>

                            <td>
                                @item.Distancia
                            </td>

                            <td>
                                @item.TamanhoCamisa
                            </td>

                            <td>

                                @if (item.Status == "Confirmada")
                                {
                                    <span class="badge-status badge-confirmado">
                                        Confirmada
                                    </span>
                                }
                                else if (item.Status == "Cancelada")
                                {
                                    <span class="badge-status badge-cancelado">
                                        Cancelada
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-status badge-pendente">
                                        @item.Status
                                    </span>
                                }

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </section>

</main>

@section Scripts {

    <link rel="stylesheet"
          href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>

        $(function () {

            $('#tabelaInscricoes').DataTable({

                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/pt-BR.json"
                },

                pageLength:10,

                order:[[0,'asc']]

            });

        });

    </script>

}