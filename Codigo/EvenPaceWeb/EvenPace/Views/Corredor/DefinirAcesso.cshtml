@model Models.CorredorViewModel

@{
    Layout = null;
}

<!doctype html>
<html lang="pt-br">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>EvenPace - Definir Acesso</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .gradient-custom {
            background: linear-gradient(180deg, #FFD700 0%, #FFD700 60%, #111111 100%);
        }
    </style>
</head>
<body>
    <section class="vh-100 gradient-custom d-flex align-items-center">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-md-8 col-lg-6 col-xl-5">
                    <div class="card bg-dark text-white shadow-lg" style="border-radius: 1rem;">
                        <div class="card-body p-5 text-center">
                            <h2 class="fw-bold mb-2 text-uppercase">Acesso</h2>
                            <p class="text-white-50 mb-5">Defina seu e-mail e senha para o CPF: @ViewBag.Cpf</p>

                            <form asp-action="FinalizarCadastro" method="post">
                                @* Campo oculto para manter o vínculo com o corredor criado *@
                                <input type="hidden" name="CPF" value="@ViewBag.Cpf" />

                                <div class="mb-4 text-start">
                                    <label class="form-label">E-mail</label>
                                    <input name="Email" type="email" class="form-control form-control-lg" placeholder="email@exemplo.com" required />
                                </div>

                                <div class="mb-4 text-start">
                                    <label class="form-label">Senha</label>
                                    <input name="Senha" type="password" class="form-control form-control-lg" placeholder="******" required />
                                </div>

                                <div class="d-grid gap-2 mb-4">
                                    <button class="btn btn-outline-light btn-lg" type="submit">
                                        Finalizar Cadastro
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</body>
</html>
