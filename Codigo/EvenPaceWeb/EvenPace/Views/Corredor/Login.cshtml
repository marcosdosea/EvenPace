@model Models.CorredorViewModel

@{
    Layout = null;
}

<!doctype html>
<html lang="pt-br">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>EvenPace - Login Corredor</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        .gradient-custom {
            background: linear-gradient(180deg, #FFD700 0%, #FFD700 60%, #111111 100%);
            min-height: 100vh;
        }

        .evenpace-bg-dark {
            background-color: #1a1a1a !important;
            border: 2px solid #333;
            border-radius: 1rem;
        }

        .evenpace-text-yellow {
            color: #FFD700 !important;
        }

        .evenpace-btn-yellow {
            background-color: #FFD700;
            color: #000000;
            font-weight: 700;
            border: none;
            transition: all 0.3s ease;
        }

            .evenpace-btn-yellow:hover {
                background-color: #e0a800;
                color: #000000;
                transform: translateY(-1px);
                box-shadow: 0 4px 12px rgba(255, 215, 0, 0.3);
            }

        .evenpace-input {
            background-color: #2b2b2b !important;
            border: 1px solid #444 !important;
            color: #ffffff !important;
        }

            .evenpace-input:focus {
                border-color: #FFD700 !important;
                box-shadow: 0 0 0 0.25rem rgba(255, 215, 0, 0.25) !important;
            }

        .evenpace-label {
            color: #aaa !important;
        }

        .form-floating > .evenpace-input:focus ~ .evenpace-label,
        .form-floating > .evenpace-input:not(:placeholder-shown) ~ .evenpace-label {
            color: #FFD700 !important;
        }

        .evenpace-link {
            color: #FFD700;
            text-decoration: none;
            transition: color 0.2s ease;
        }

            .evenpace-link:hover {
                color: #e0a800;
                text-decoration: underline;
            }
    </style>
</head>

<body>

    <section class="gradient-custom d-flex align-items-center py-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-md-8 col-lg-6 col-xl-5">
                    <div class="card shadow-lg evenpace-bg-dark p-2 p-md-4">
                        <div class="card-body">

                            <div class="text-center mb-4">
                                <h2 class="fw-bold text-uppercase text-light">Login <span class="evenpace-text-yellow">Corredor</span></h2>
                                <p class="text-muted small">Bem-vindo à comunidade EvenPace</p>
                            </div>

                            <form asp-controller="Corredor" asp-action="Login" method="post">
                                @Html.AntiForgeryToken()

                                <div class="form-floating mb-3">
                                    <input type="email" id="email" name="email" class="form-control evenpace-input" placeholder="Email" required>
                                    <label for="email" class="evenpace-label">Email</label>
                                </div>

                                <div class="form-floating mb-3">
                                    <input type="text" id="cpf" name="cpf" class="form-control evenpace-input" placeholder="CPF" required>
                                    <label for="cpf" class="evenpace-label">CPF</label>
                                </div>

                                <div class="form-floating mb-3">
                                    <input type="password" id="senha" name="senha" class="form-control evenpace-input" placeholder="Senha" required>
                                    <label for="senha" class="evenpace-label">Senha</label>
                                </div>

                                <div class="text-center mb-4">
                                    <a class="evenpace-link small" href="/esqueci-senha">Esqueci a senha</a>
                                </div>

                                <div class="d-grid gap-2 mb-4">
                                    <button class="btn btn-lg evenpace-btn-yellow shadow-sm" type="submit">
                                        Entrar
                                    </button>
                                </div>

                                <hr class="border-secondary">

                                <div class="d-grid gap-2 mb-3">
                                    <button class="btn btn-outline-light btn-lg" type="button">
                                        Entrar com Google
                                    </button>
                                </div>

                                <div class="d-grid gap-2">
                                    <a href="http://localhost:5157/Corredor/Create" class="btn btn-outline-warning btn-lg fw-bold" style="border-color: #FFD700; color: #FFD700;">
                                        Cadastre-se Manualmente
                                    </a>
                                </div>
                            </form>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>