@model Models.CartaoCreditoViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pagamento</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #f5f5f5;
        }

        .app-container {
            max-width: 430px; /* tamanho padrão celular */
            min-height: 100vh;
            margin: auto;
            background: white;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .content {
            padding: 25px;
        }

        .btn-concluir {
            background-color: #ffd400;
            border: none;
            font-weight: 600;
        }

        .btn-concluir:hover {
            background-color: #e6c200;
        }

        .bottom-nav {
            border-top: 1px solid #ddd;
            display: flex;
            justify-content: space-around;
            padding: 10px 0;
            font-size: 14px;
            background: white;
        }

        .bottom-nav div {
            text-align: center;
        }
    </style>
</head>

<body>

<div class="app-container">

    <div class="content">

        <div class="mb-3">
            <a asp-controller="Inscricao" asp-action="Create" style="text-decoration:none;">←</a>
        </div>

        <h5 class="text-center mb-4">Informações do Cartão</h5>

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label">Número do cartão</label>
                <input asp-for="Numero" class="form-control" />
            </div>

            <div class="row">
                <div class="col-6 mb-3">
                    <label class="form-label">Data de validade</label>
                    <input asp-for="DataValidade" class="form-control" placeholder="MM/AA" />
                </div>

                <div class="col-6 mb-3">
                    <label class="form-label">CVV</label>
                    <input asp-for="CodigoSeguranca" class="form-control" />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label">Nome no cartão</label>
                <input asp-for="Nome" class="form-control" />
            </div>

            <button type="submit" class="btn btn-concluir w-100">
                Concluir
            </button>

        </form>
    </div>

    <!-- BOTTOM NAV -->
    <div class="bottom-nav">
        <div>🏠<br>Início</div>
        <div>🏆<br>Conquistas</div>
        <div>🎟️<br>Cupons</div>
        <div>🕓<br>Histórico</div>
        <div>👤<br>Perfil</div>
    </div>

</div>

</body>
</html>