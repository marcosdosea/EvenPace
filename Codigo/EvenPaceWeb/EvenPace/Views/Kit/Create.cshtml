@model Models.KitViewModel
@{
    ViewData["Title"] = "Criar Kit";
    Layout = "~/Views/Shared/_LayoutOrganizacao.cshtml";
    <link rel="stylesheet" href="~/css/kit.css" />
}

<style>
    .page-head {
        background: linear-gradient(135deg, #fffdf4, #ffffff);
        border: 1px solid #ece7d5;
        border-radius: 26px;
        padding: 22px;
        box-shadow: 0 18px 40px rgba(18, 18, 18, 0.06);
        margin-bottom: 22px;
    }

        .page-head h1 {
            margin: 0;
            font-size: 2.2rem;
            font-weight: 800;
            letter-spacing: -0.03em;
        }

    .subtitle {
        margin: 8px 0 0;
        color: #6f7780;
    }
</style>

<main class="main-container">
    <header class="page-head">
        <h1>Criar Kit</h1>
        <p class="subtitle">@ViewBag.NomeCorrida</p>
    </header>

    @* Caixa com fundo branco, sombra e preenchimento consistente *@
    <div class="form-card-bg" style="max-width: 800px; margin: 0 auto; padding: 25px; background: #ffffff; border-radius: 20px; border: 1px solid #e0e0e0; box-shadow: 0 4px 15px rgba(0,0,0,.03);">
        <form asp-action="Create" method="post" enctype="multipart/form-data" class="form-kits">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Imagem" />
            <input type="hidden" asp-for="IdEvento" />

            <div class="form-block">
                <label asp-for="Nome" class="label-bold">Nome</label>
                <input asp-for="Nome" class="input-gray" placeholder="Ex: Kit Premium" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <div class="row-flex">
                <div class="col-fixed">
                    <label asp-for="Valor" class="label-bold">Valor</label>
                    <input asp-for="Valor" class="input-gray" placeholder="R$ 0,00" />
                    <span asp-validation-for="Valor" class="text-danger"></span>
                </div>
                <div class="col-grow">
                    <label class="label-bold">Imagem</label>
                    <div class="input-wrapper">
                        <input type="text" class="input-gray" placeholder="Nenhum arquivo" readonly />
                        <span class="icon-upload" aria-hidden="true">⬆️</span>
                        <input type="file" name="imagemUpload" class="file-hidden" />
                    </div>
                </div>
            </div>

            <div class="row-flex">
                <div class="col-grow desc-area">
                    <label asp-for="Descricao" class="label-bold">Descrição</label>
                    <textarea asp-for="Descricao" class="input-gray" rows="8"></textarea>
                    <span asp-validation-for="Descricao" class="text-danger"></span>
                </div>
                <div class="col-grow sizes-fieldset" style="border: 1px solid #eee; padding: 20px; border-radius: 8px;">
                    <legend class="legend-title">Disponibilidade</legend>
                    <div class="header-sizes"><strong>Tamanho</strong><strong>Quantidade</strong></div>
                    <label class="size-row"><span>P</span><input asp-for="DisponibilidadeP" type="number" min="0" class="input-qtd" /></label>
                    <label class="size-row"><span>M</span><input asp-for="DisponibilidadeM" type="number" min="0" class="input-qtd" /></label>
                    <label class="size-row"><span>G</span><input asp-for="DisponibilidadeG" type="number" min="0" class="input-qtd" /></label>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-green">Salvar</button>
                <a asp-action="IndexKit" asp-route-idEvento="@Model.IdEvento" class="btn-gray">Voltar</a>
            </div>
        </form>
    </div>
</main>
<script src="~/js/kit.js"></script>