<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EvenPace</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --evenpace-bg: #ffffff;
            --evenpace-surface: #fffdf6;
            --evenpace-line: #f1e2b6;
            --evenpace-line-strong: #edd58a;
            --evenpace-text: #202124;
            --evenpace-muted: #6b7280;
            --evenpace-accent: #f7cf66;
            --evenpace-accent-soft: #fff4cf;
            --evenpace-accent-shadow: rgba(231, 188, 69, 0.16);
        }

        html, body {
            min-height: 100%;
            background: var(--evenpace-bg);
            color: var(--evenpace-text);
            font-family: "Manrope", sans-serif;
        }

        body {
            margin: 0;
        }

        .evenpace-public-header {
            position: sticky;
            top: 0;
            z-index: 1030;
            background: rgba(255, 255, 255, 0.96);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(237, 213, 138, 0.55);
        }

        .evenpace-brand {
            display: inline-flex;
            align-items: center;
            gap: 0.75rem;
            color: var(--evenpace-text);
            text-decoration: none;
        }

        .evenpace-brand:hover {
            color: var(--evenpace-text);
        }

        .evenpace-logo {
            width: auto;
            height: 48px;
            object-fit: contain;
        }

        .evenpace-brand-name {
            font-size: 1.35rem;
            font-weight: 800;
            letter-spacing: 0;
        }

        .evenpace-header-link,
        .evenpace-header-action,
        .evenpace-profile-chip,
        .evenpace-instagram-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 46px;
            border-radius: 999px;
            text-decoration: none;
            transition: transform 0.18s ease, box-shadow 0.18s ease, background-color 0.18s ease, color 0.18s ease;
        }

        .evenpace-header-link {
            padding: 0.55rem 1rem;
            color: var(--evenpace-text);
            font-weight: 700;
        }

        .evenpace-header-link:hover {
            background: var(--evenpace-surface);
            color: var(--evenpace-text);
        }

        .evenpace-instagram-link {
            width: 46px;
            height: 46px;
            color: #27272a;
            background: #ffffff;
            border: 1px solid var(--evenpace-line);
        }

        .evenpace-instagram-link svg {
            width: 23px;
            height: 23px;
            fill: currentColor;
        }

        .evenpace-instagram-link:hover {
            color: #71550c;
            background: var(--evenpace-accent-soft);
            box-shadow: 0 10px 24px var(--evenpace-accent-shadow);
            transform: translateY(-1px);
        }

        .evenpace-header-action {
            padding: 0.7rem 1.15rem;
            font-weight: 800;
            border: 1px solid transparent;
        }

        .evenpace-header-action-secondary {
            background: var(--evenpace-accent-soft);
            color: #71550c;
            border-color: var(--evenpace-line);
        }

        .evenpace-header-action-secondary:hover {
            color: #4d3a08;
            box-shadow: 0 10px 24px var(--evenpace-accent-shadow);
            transform: translateY(-1px);
        }

        .evenpace-header-action-primary {
            background: linear-gradient(135deg, #ffe7a6, #f7cf66);
            color: #443200;
            border-color: #f0d07e;
            box-shadow: 0 10px 24px var(--evenpace-accent-shadow);
        }

        .evenpace-header-action-primary:hover {
            color: #2d2203;
            transform: translateY(-1px);
        }

        .evenpace-profile-dropdown .dropdown-toggle::after {
            margin-left: 0.45rem;
            vertical-align: 0.12em;
        }

        .evenpace-profile-menu {
            min-width: 180px;
            padding: 0.4rem;
            border: 1px solid var(--evenpace-line);
            border-radius: 12px;
            box-shadow: 0 18px 36px rgba(32, 33, 36, 0.12);
        }

        .evenpace-profile-menu-item {
            min-height: 42px;
            border-radius: 8px;
            color: var(--evenpace-text);
            font-weight: 700;
        }

        .evenpace-profile-menu-item:hover,
        .evenpace-profile-menu-item:focus {
            background: var(--evenpace-accent-soft);
            color: #4d3a08;
        }

        .evenpace-profile-menu .evenpace-profile-logout,
        .evenpace-profile-menu .evenpace-profile-logout.active {
            color: var(--evenpace-text) !important;
            box-shadow: none !important;
            text-decoration: none !important;
        }

        .evenpace-profile-menu .evenpace-profile-logout:hover,
        .evenpace-profile-menu .evenpace-profile-logout:focus,
        .evenpace-profile-menu .evenpace-profile-logout:active,
        .evenpace-profile-menu .evenpace-profile-logout:focus-visible {
            background-color: var(--evenpace-accent-soft) !important;
            color: #4d3a08 !important;
            box-shadow: none !important;
            text-decoration: none !important;
        }

        .evenpace-profile-chip {
            width: 46px;
            height: 46px;
            background: var(--evenpace-accent-soft);
            border: 1px solid var(--evenpace-line);
            box-shadow: 0 10px 24px var(--evenpace-accent-shadow);
        }

        .evenpace-profile-icon {
            width: 22px;
            height: 22px;
            color: #6e5410;
        }

        .evenpace-profile-icon svg {
            width: 100%;
            height: 100%;
            fill: currentColor;
        }

        main {
            min-height: calc(100vh - 90px);
        }

        @@media (max-width: 991.98px) {
            .evenpace-logo {
                height: 42px;
            }

            .evenpace-brand-name {
                font-size: 1.1rem;
            }

            .evenpace-header-link,
            .evenpace-header-action {
                min-height: 42px;
                font-size: 0.95rem;
            }
        }

        @@media (max-width: 575.98px) {
            .evenpace-public-header nav {
                width: 100%;
                justify-content: space-between !important;
            }

            .evenpace-header-action {
                flex: 1 1 auto;
                padding-inline: 0.85rem;
            }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @await Html.PartialAsync("_PublicHeader")

    <main role="main">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
