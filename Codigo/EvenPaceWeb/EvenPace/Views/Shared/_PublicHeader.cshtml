<header class="evenpace-public-header">
    <div class="container-fluid px-3 px-lg-5">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 py-3 py-lg-4">
            <a class="evenpace-brand" href="@Url.Action("IndexUsuario", "Evento")">
                <img src="~/imagens/logo-amarela-evenpace.jpeg" alt="EvenPace" class="evenpace-logo" />
                <span class="evenpace-brand-name">EvenPace</span>
            </a>

            <nav class="d-flex flex-wrap align-items-center justify-content-end gap-2 gap-lg-3">
                <a class="evenpace-instagram-link" href="https://www.instagram.com/" target="_blank" rel="noopener noreferrer" aria-label="Instagram EvenPace">
                    <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                        <path d="M7.75 2h8.5A5.76 5.76 0 0 1 22 7.75v8.5A5.76 5.76 0 0 1 16.25 22h-8.5A5.76 5.76 0 0 1 2 16.25v-8.5A5.76 5.76 0 0 1 7.75 2Zm0 2A3.75 3.75 0 0 0 4 7.75v8.5A3.75 3.75 0 0 0 7.75 20h8.5A3.75 3.75 0 0 0 20 16.25v-8.5A3.75 3.75 0 0 0 16.25 4h-8.5Zm4.25 3.25A4.75 4.75 0 1 1 7.25 12 4.75 4.75 0 0 1 12 7.25Zm0 2A2.75 2.75 0 1 0 14.75 12 2.75 2.75 0 0 0 12 9.25ZM17.25 6.7a1.05 1.05 0 1 1-1.05 1.05 1.05 1.05 0 0 1 1.05-1.05Z" />
                    </svg>
                </a>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    var perfilUrl = ViewBag.IdCorredor is not null
                        ? Url.Action("Get", "Corredor", new { id = ViewBag.IdCorredor })
                        : Url.Action("IndexUsuario", "Evento");

                    <div class="dropdown evenpace-profile-dropdown">
                        <button class="evenpace-header-action evenpace-header-action-primary dropdown-toggle"
                                type="button"
                                id="perfilDropdown"
                                data-bs-toggle="dropdown"
                                aria-expanded="false">
                            Perfil
                        </button>

                        <ul class="dropdown-menu dropdown-menu-end evenpace-profile-menu" aria-labelledby="perfilDropdown">
                            <li>
                                <a class="dropdown-item evenpace-profile-menu-item" href="@perfilUrl">
                                    Meu Perfil
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item evenpace-profile-menu-item" href="@Url.Action("IndexCorridasInscritas", "Inscricao")">
                                    Minhas Corridas
                                </a>
                            </li>
                            <li>
                                <form asp-area="Identity"
                                      asp-page="/Account/Logout"
                                      asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
                                      method="post">
                                    <button type="submit" class="dropdown-item evenpace-profile-menu-item evenpace-profile-logout">
                                        Desconectar
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a class="evenpace-header-action evenpace-header-action-secondary" href="@Url.Action("Login", "Organizacao")">
                        Crie sua corrida
                    </a>

                    <a class="evenpace-header-action evenpace-header-action-primary" href="@Url.Action("Login", "Corredor")">
                        Entrar
                    </a>
                }
            </nav>
        </div>
    </div>
</header>
