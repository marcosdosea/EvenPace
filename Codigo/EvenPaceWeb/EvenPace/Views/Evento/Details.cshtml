@model Models.EventoViewModel

@{
    ViewData["Title"] = "Detalhes do Evento";
    Layout = "~/Views/Shared/_LayoutOrganizacao.cshtml";

    // Lógica do Placeholder
    string imagemSrc = !string.IsNullOrEmpty(Model.Imagem)
        ? "/imagens/banner-eventos/" + Model.Imagem
        : "https://placehold.co/300x180?text=EvenPace";
}

<link rel="stylesheet" href="~/css/evento-detalhes.css" />

@if (Model != null)
{
    <div class="main-container">
        <div class="banner-wrapper">
            <img src="@imagemSrc" class="banner-img" alt="@Model.Nome">
        </div>

        <header class="page-header" style="margin-bottom: 30px;">
            <h1>@Model.Nome</h1>
        </header>

        <div class="event-info-section">
            <div class="card-info">
                <h3>Sobre o evento</h3>
                <p><strong>Data:</strong> @Model.Data.ToString("dd/MM/yyyy HH:mm")</p>
                <p><strong>Descrição:</strong> @Model.Descricao</p>
                <p><strong>Local:</strong> @Model.Cidade - @Model.Estado</p>
            </div>

            <div class="card-info" style="border-left: 5px solid #FEEA00;">
                <h3>Ações do Evento</h3>
                <div class="mt-3">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-action btn-edit">
                        ✏️ Editar Evento
                    </a>

                    <button type="button" class="btn-action btn-delete"
                            onclick="confirmarExclusao(@Model.Id, '@Model.Nome')">
                        🗑️ Excluir Evento
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        function confirmarExclusao(id, nome) {
            if (confirm('Tem certeza que deseja excluir o evento "' + nome + '"? Esta ação é irreversível.')) {
                window.location.href = '@Url.Action("Delete", "Evento")/' + id;
            }
        }
    </script>
}