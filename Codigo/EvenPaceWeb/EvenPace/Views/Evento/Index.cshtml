@model IEnumerable<Models.EventoViewModel>

@{
    ViewData["Title"] = "Meus Eventos";
    Layout = "~/Views/Shared/_LayoutOrganizacaoHome.cshtml";
}

<style>
    .content-area {
        flex-grow: 1;
        background: #fff;
        padding: 40px;
        overflow-x: hidden;
    }

    /* Cabeçalho */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
        flex-wrap: wrap;
        gap: 20px;
    }

    .header-title-group {
        display: flex;
        align-items: center;
    }

    .header-text h1 {
        margin: 0;
        font-size: 2rem;
        font-weight: 800;
        color: #1f2937;
    }

    .subtitle {
        margin-top: 8px;
        color: #6b7280;
        font-size: 1rem;
    }

    /* Botão verde padrão do sistema */
    .btn-green {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: #28a745;
        color: #fff;
        text-decoration: none;
        padding: 12px 24px;
        border-radius: 12px;
        font-weight: 700;
        transition: .25s;
        box-shadow: 0 6px 18px rgba(40,167,69,.20);
    }

        .btn-green:hover {
            background: #218838;
            color: #fff;
            transform: translateY(-2px);
        }

    .btn-symbol {
        font-size: 22px;
        line-height: 1;
    }

    .section-title {
        text-align: center;
        font-size: 1.8rem;
        font-weight: 800;
        color: #1f2937;
        margin-bottom: 35px;
    }

    /* Cards */
    .event-card-link {
        display: block;
        text-decoration: none;
        color: inherit;
        transition: .25s;
    }

        .event-card-link:hover {
            transform: translateY(-6px);
        }

    .event-card-container {
        margin-bottom: 20px;
    }

    .image-wrapper {
        background: #fff;
        border-radius: 18px;
        overflow: hidden;
        border: 1px solid #ececec;
        box-shadow: 0 8px 25px rgba(0,0,0,.06);
    }

    .event-img {
        width: 100%;
        height: 210px;
        object-fit: cover;
        display: block;
    }

    .event-label-yellow {
        background: #FFD54F;
        color: #222;
        padding: 14px;
        text-align: center;
        font-weight: 700;
        font-size: 1rem;
    }

    .empty-state-card {
        background: #fff;
        border: 2px dashed #d9d9d9;
        border-radius: 20px;
        padding: 60px;
        text-align: center;
        max-width: 700px;
        margin: auto;
    }

        .empty-state-card h3 {
            font-weight: 800;
            margin-bottom: 10px;
        }

        .empty-state-card p {
            color: #6b7280;
            margin-bottom: 25px;
        }

    @@media(max-width:768px) {

        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .header-text h1 {
            font-size: 1.6rem;
        }

        .btn-green {
            width: 100%;
            justify-content: center;
        }
    }

</style>

<header class="page-header">

    <div class="header-title-group">

        <div class="header-text">
            <h1>Olá, @ViewBag.NomeOrganizacao 👋</h1>

            <p class="subtitle">
                Seja bem-vindo(a)! Gerencie seus eventos e acompanhe todas as informações da sua organização.
            </p>

        </div>

    </div>

    <a asp-controller="Evento"
       asp-action="Create"
       class="btn-green">

        <span class="btn-symbol">+</span>

        <span>Criar Evento</span>

    </a>

</header>

<div class="container-fluid p-0">

    <h2 class="section-title">
        Meus Eventos
    </h2>

    <div class="row g-5">
        @if (Model != null && Model.Any())
        {
            @foreach (var evento in Model)
            {
                <div class="col-12 col-sm-6 col-lg-4 col-xl-3">

                    <div class="event-card-container">

                        <a asp-controller="Evento"
                           asp-action="Details"
                           asp-route-id="@evento.Id"
                           class="event-card-link">

                            <div class="image-wrapper">

                                @if (!string.IsNullOrEmpty(evento.Imagem))
                                {
                                    <img src="@Url.Content("~/imagens/banner-eventos/" + evento.Imagem)"
                                         class="event-img"
                                         alt="@evento.Nome" />
                                }
                                else
                                {
                                    <img src="https://placehold.co/600x400/f5f5f5/888888?text=EvenPace"
                                         class="event-img"
                                         alt="@evento.Nome" />
                                }

                                <div class="event-label-yellow">
                                    @evento.Nome
                                </div>

                            </div>

                        </a>

                    </div>

                </div>
            }
        }
        else
        {
            <div class="col-12">

                <div class="empty-state-card">

                    <h3>
                        Nenhum evento encontrado
                    </h3>

                    <p>
                        Você ainda não criou nenhum evento.
                        Clique no botão abaixo para criar seu primeiro evento e começar
                        a gerenciar inscrições, kits, cupons e muito mais.
                    </p>

                    <a asp-controller="Evento"
                       asp-action="Create"
                       class="btn-green">

                        <span class="btn-symbol">+</span>

                        <span>Criar Evento</span>

                    </a>

                </div>

            </div>
        }

    </div>

</div>