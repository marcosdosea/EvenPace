@model IEnumerable<Models.EventoViewModel>

@{
    ViewData["Title"] = "Meus Eventos";
    Layout = "~/Views/Shared/_LayoutOrganizacaoHome.cshtml";
}

<style>
    /* Notificação Toast */
    .toast-mensagem {
        position: fixed;
        top: 140px;
        right: 20px;
        z-index: 1000;
        background: #d4edda;
        color: #155724;
        padding: 15px 25px;
        border-radius: 8px;
        border-left: 5px solid #28a745;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        transition: opacity 0.5s;
    }

    @@keyframes slideInRight {
        from {
            transform: translateX(100%);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }
    }

    .content-area {
        flex-grow: 1;
        background: #fff;
        padding: 40px;
        overflow-x: hidden;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
        flex-wrap: wrap;
        gap: 20px;
    }

    .header-title-group {
        display: flex;
        align-items: center;
    }

    .header-text h1 {
        margin: 0;
        font-size: 2rem;
        font-weight: 800;
        color: #1f2937;
    }

    .subtitle {
        margin-top: 8px;
        color: #6b7280;
        font-size: 1rem;
    }

    .btn-green {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: #28a745;
        color: #fff;
        text-decoration: none;
        padding: 12px 24px;
        border-radius: 12px;
        font-weight: 700;
        transition: .25s;
        box-shadow: 0 6px 18px rgba(40,167,69,.20);
    }

        .btn-green:hover {
            background: #218838;
            color: #fff;
            transform: translateY(-2px);
        }

    .btn-symbol {
        font-size: 22px;
        line-height: 1;
    }

    .section-title {
        text-align: center;
        font-size: 1.8rem;
        font-weight: 800;
        color: #1f2937;
        margin-bottom: 35px;
    }

    .event-card-link {
        display: block;
        text-decoration: none;
        color: inherit;
        transition: .25s;
    }

        .event-card-link:hover {
            transform: translateY(-6px);
        }

    .event-card-container {
        margin-bottom: 20px;
    }

    .image-wrapper {
        background: #fff;
        border-radius: 18px;
        overflow: hidden;
        border: 1px solid #ececec;
        box-shadow: 0 8px 25px rgba(0,0,0,.06);
    }

    .event-img {
        width: 100%;
        height: 210px;
        object-fit: cover;
        display: block;
    }

    .event-label-yellow {
        background: #FFD54F;
        color: #222;
        padding: 14px;
        text-align: center;
        font-weight: 700;
        font-size: 1rem;
    }

    .empty-state-card {
        background: #fff;
        border: 2px dashed #d9d9d9;
        border-radius: 20px;
        padding: 60px;
        text-align: center;
        max-width: 700px;
        margin: auto;
    }

    @@media(max-width:768px) {
        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .header-text h1 {
            font-size: 1.6rem;
        }

        .btn-green {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<main class="main-container">

    <!-- Notificação de Sucesso que aparece no canto -->
    @if (TempData["MensagemSucesso"] != null)
    {
        <div id="toast-sucesso" class="toast-mensagem">
            @TempData["MensagemSucesso"]
        </div>
    }

    <header class="page-header">
        <div class="header-title-group">
            <div class="header-text">
                <h1>Olá, @ViewBag.NomeOrganizacao 👋</h1>
                <p class="subtitle">Seja bem-vindo(a)! Gerencie seus eventos.</p>
            </div>
        </div>
        <a asp-controller="Evento" asp-action="Create" class="btn-green">
            <span class="btn-symbol">+</span>
            <span>Criar Evento</span>
        </a>
    </header>

    <div class="container-fluid p-0">
        <h2 class="section-title">Meus Eventos</h2>
        <div class="row g-5">
            @if (Model != null && Model.Any())
            {
                @foreach (var evento in Model)
                {
                    <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                        <div class="event-card-container">
                            <a asp-controller="Evento" asp-action="Details" asp-route-id="@evento.Id" class="event-card-link">
                                <div class="image-wrapper">
                                    @if (!string.IsNullOrEmpty(evento.Imagem))
                                    {
                                        <img src="@Url.Content("~/imagens/banner-eventos/" + evento.Imagem)" class="event-img" alt="@evento.Nome" />
                                    }
                                    else
                                    {
                                        <img src="https://placehold.co/600x400/f5f5f5/888888?text=EvenPace" class="event-img" alt="@evento.Nome" />
                                    }
                                    <div class="event-label-yellow">@evento.Nome</div>
                                </div>
                            </a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="empty-state-card">
                        <h3>Nenhum evento encontrado</h3>
                        <p>Você ainda não criou nenhum evento. Clique abaixo para começar.</p>
                        <a asp-controller="Evento" asp-action="Create" class="btn-green"><span>Criar Evento</span></a>
                    </div>
                </div>
            }
        </div>
    </div>
</main>

<script>
    // Script para remover a notificação após 4 segundos
    setTimeout(function() {
        var toast = document.getElementById('toast-sucesso');
        if (toast) {
            toast.style.opacity = '0';
            setTimeout(() => toast.remove(), 500);
        }
    }, 4000);
</script>