@model Models.CupomViewModel

@{
    ViewData["Title"] = "Editar Cupom";
    Layout = "~/Views/Shared/_LayoutOrganizacao.cshtml";
    <link rel="stylesheet" href="~/css/kit.css" />
}

<main class="main-container">

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="alert alert-danger"></div>
    }

    <header class="page-header">
        <div class="header-titles">
            <h1>Editar Cupom</h1>
            <p class="subtitle">@ViewBag.NomeCorrida</p>
        </div>
    </header>

    <form asp-action="Edit" method="post" class="form-kits">

        <input asp-for="Id" type="hidden" />
        <input asp-for="IdEvento" type="hidden" />

        <div class="form-block">
            <label asp-for="Nome" class="label-bold">Nome do Cupom</label>
            <input asp-for="Nome"
                   class="input-gray"
                   placeholder="Ex: VERAO20" />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>

        <div class="row-flex">

            <div class="col-fixed">
                <label asp-for="Desconto" class="label-bold">
                    Desconto (%)
                </label>
                <input asp-for="Desconto"
                       type="number"
                       class="input-gray" />
                <span asp-validation-for="Desconto"
                      class="text-danger"></span>
            </div>

            <div class="col-grow">
                <label asp-for="QuantiadeDisponibilizada"
                       class="label-bold">
                    Quantidade Disponível
                </label>
                <input asp-for="QuantiadeDisponibilizada"
                       type="number"
                       class="input-gray" />
                <span asp-validation-for="QuantiadeDisponibilizada"
                      class="text-danger"></span>
            </div>

        </div>

        <div class="row-flex">

            <div class="col-grow">
                <label asp-for="DataInicio"
                       class="label-bold">
                    Data de Início
                </label>

                <input asp-for="DataInicio"
                       type="date"
                       class="input-gray" />

                <span asp-validation-for="DataInicio"
                      class="text-danger"></span>
            </div>

            <div class="col-grow">
                <label asp-for="DataTermino"
                       class="label-bold">
                    Data de Término
                </label>

                <input asp-for="DataTermino"
                       type="date"
                       class="input-gray" />

                <span asp-validation-for="DataTermino"
                      class="text-danger"></span>
            </div>

        </div>

        <div class="form-block">

            <fieldset class="sizes-fieldset">

                <legend class="legend-title">
                    Status do Cupom
                </legend>

                <label class="size-row" style="margin-bottom:0;">

                    <span id="status-text"></span>

                    <input asp-for="Status"
                           type="checkbox"
                           id="status-toggle"
                           style="width:22px;height:22px;" />

                </label>

            </fieldset>

        </div>

        <div class="form-actions">

            <button type="submit"
                    class="btn-green">
                Atualizar
            </button>

            <a asp-action="Index"
               asp-route-idEvento="@Model.IdEvento"
               class="btn-gray">
                Voltar
            </a>

        </div>

    </form>

</main>

<script>
    const toggle = document.getElementById("status-toggle");
    const statusText = document.getElementById("status-text");

    function atualizarStatus() {
        if (toggle.checked) {
            statusText.textContent = "Ativo";
            statusText.style.color = "#28a745";
        } else {
            statusText.textContent = "Desativado";
            statusText.style.color = "#dc3545";
        }
    }

    atualizarStatus();

    toggle.addEventListener("change", atualizarStatus);
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}