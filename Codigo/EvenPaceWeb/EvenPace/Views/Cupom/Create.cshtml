@model Models.CupomViewModel

@{
    ViewData["Title"] = "Criar Cupom";
    Layout = "~/Views/Shared/_LayoutOrganizacao.cshtml";
    <link rel="stylesheet" href="~/css/kit.css" />
}

<style>
    .page-head {
        background: linear-gradient(135deg, #fffdf4, #ffffff);
        border: 1px solid #ece7d5;
        border-radius: 26px;
        padding: 22px;
        box-shadow: 0 18px 40px rgba(18, 18, 18, 0.06);
        margin-bottom: 22px;
    }

        .page-head h1 {
            margin: 0;
            font-size: 2.2rem;
            font-weight: 800;
            letter-spacing: -0.03em;
        }

    .subtitle {
        margin: 8px 0 0;
        color: #6f7780;
    }
</style>

<main class="main-container">
    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="alert alert-danger"></div>
    }

    <header class="page-head">
        <h1>Criar Cupom</h1>
        <p class="subtitle">@ViewBag.NomeCorrida</p>
    </header>

    @* Adicionada a classe 'form-card-bg' para o fundo branco e 'style' para o preenchimento *@
    <form asp-action="Create" method="post" class="form-kits"
          style="background: #ffffff; padding: 40px; border-radius: 20px; border: 1px solid #e0e0e0; box-shadow: 0 4px 15px rgba(0,0,0,0.03);">
        <input asp-for="IdEvento" type="hidden" />

        <div class="form-block">
            <label asp-for="Nome" class="label-bold">Nome do Cupom</label>
            <input asp-for="Nome" class="input-gray" placeholder="Ex: VERAO20" />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>

        <div class="row-flex">
            <div class="col-fixed">
                <label asp-for="Desconto" class="label-bold">Desconto (%)</label>
                <input asp-for="Desconto" type="number" class="input-gray" placeholder="10" />
                <span asp-validation-for="Desconto" class="text-danger"></span>
            </div>
            <div class="col-grow">
                <label asp-for="QuantiadeDisponibilizada" class="label-bold">Quantidade Disponível</label>
                <input asp-for="QuantiadeDisponibilizada" type="number" class="input-gray" />
                <span asp-validation-for="QuantiadeDisponibilizada" class="text-danger"></span>
            </div>
        </div>

        <div class="row-flex">
            <div class="col-grow">
                <label asp-for="DataInicio" class="label-bold">Data de Início</label>
                <input asp-for="DataInicio" type="date" class="input-gray" />
                <span asp-validation-for="DataInicio" class="text-danger"></span>
            </div>
            <div class="col-grow">
                <label asp-for="DataTermino" class="label-bold">Data de Término</label>
                <input asp-for="DataTermino" type="date" class="input-gray" />
                <span asp-validation-for="DataTermino" class="text-danger"></span>
            </div>
        </div>

        <div class="form-block">
            <fieldset class="sizes-fieldset">
                <legend class="legend-title">Status do Cupom</legend>
                <label class="size-row" style="margin-bottom:0;">
                    <span id="status-text">Ativo</span>
                    <input asp-for="Status" type="checkbox" id="status-toggle" style="width:22px;height:22px;" checked />
                </label>
            </fieldset>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-green">Salvar</button>
            <a asp-action="Index" asp-route-idEvento="@ViewBag.IdEventoAtual" class="btn-gray">Voltar</a>
        </div>
    </form>
</main>

<script>
    const toggle = document.getElementById("status-toggle");
    const statusText = document.getElementById("status-text");
    function atualizarStatus() {
        if (toggle.checked) { statusText.textContent = "Ativo"; statusText.style.color = "#28a745"; }
        else { statusText.textContent = "Desativado"; statusText.style.color = "#dc3545"; }
    }
    atualizarStatus();
    toggle.addEventListener("change", atualizarStatus);
</script>