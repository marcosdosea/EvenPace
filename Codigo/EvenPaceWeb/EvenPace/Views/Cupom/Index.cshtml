@model IEnumerable<Models.CupomViewModel>

@{
    ViewData["Title"] = "Cupons";
    Layout = "~/Views/Shared/_LayoutOrganizacao.cshtml";
    <link rel="stylesheet" href="~/css/kit.css" />
}

<style>
    /* Padrão de Cabeçalho Elegante */
    .page-head {
        background: linear-gradient(135deg, #fffdf4, #ffffff);
        border: 1px solid #ece7d5;
        border-radius: 26px;
        padding: 22px;
        box-shadow: 0 18px 40px rgba(18, 18, 18, 0.06);
        margin-bottom: 22px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
    }

        .page-head h1 {
            margin: 0;
            font-size: 2.2rem;
            font-weight: 800;
            letter-spacing: -0.03em;
        }

    .subtitle {
        margin: 8px 0 0;
        color: #6f7780;
    }

    /* Estilo da Tabela */
    .table-container {
        max-width: 1100px;
        margin: 20px auto;
        padding: 0 20px;
    }

    .alert-custom {
        position: fixed;
        top: 140px;
        right: 20px;
        z-index: 1000;
        background: #d4edda;
        color: #155724;
        padding: 15px 25px;
        border-radius: 8px;
        border-left: 5px solid #28a745;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        transition: opacity 0.5s;
    }

    .custom-table-wrapper {
        background: #fff;
        border-radius: 20px;
        border: 1px solid #e0e0e0;
        box-shadow: 0 4px 15px rgba(0,0,0,.03);
        overflow: hidden;
    }

    .custom-table {
        width: 100%;
        border-collapse: collapse;
    }

        .custom-table th {
            background: #fafafa;
            padding: 18px 20px;
            font-weight: 700;
            border-bottom: 1px solid #eee;
            text-transform: uppercase;
        }

        .custom-table td {
            padding: 18px 20px;
            border-bottom: 1px solid #eee;
        }

    .badge-status {
        padding: 6px 12px;
        border-radius: 6px;
        font-weight: bold;
        font-size: .85rem;
    }

        .badge-status.active {
            background: #d4edda;
            color: #155724;
        }

        .badge-status.inactive {
            background: #f8d7da;
            color: #721c24;
        }
</style>

<main class="main-container">
    <form id="deleteForm">@Html.AntiForgeryToken()</form>

    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert-custom">@TempData["MensagemSucesso"]</div>
    }

    <header class="page-head">
        <div class="header-titles">
            <h1>Cupons</h1>
            <p class="subtitle">@ViewBag.NomeCorrida</p>
        </div>
        <a asp-action="Create" asp-route-idEvento="@ViewBag.IdEventoAtual" class="btn-green">
            <span class="btn-symbol">+</span> <span>Criar Cupom</span>
        </a>
    </header>

    <section class="table-container">
        @if (Model != null && Model.Any())
        {
            <div class="custom-table-wrapper">
                <table class="custom-table">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th>Início</th>
                            <th>Término</th>
                            <th style="text-align:center;">Status</th>
                            <th style="text-align:center;">Disponível</th>
                            <th style="text-align:right;">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.Nome</strong></td>
                                <td>@item.DataInicio.ToShortDateString()</td>
                                <td>@item.DataTermino.ToShortDateString()</td>
                                <td style="text-align:center;">
                                    <span class="badge-status @(item.Status ? "active" : "inactive")">
                                        @(item.Status ? "Ativo" : "Inativo")
                                    </span>
                                </td>
                                <td style="text-align:center;">@item.QuantiadeDisponibilizada</td>
                                <td style="text-align:right;">
                                    <a asp-action="Edit" asp-route-id="@item.Id" style="margin-right:15px; color:#444; font-weight:600;">✏️ Editar</a>
                                    <a href="javascript:void(0)" onclick="excluirCupom(@item.Id, '@item.Nome')" style="color:#d32f2f; font-weight:600;">🗑️ Excluir</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</main>

<script>
    function excluirCupom(id, nome) {
        if (!confirm("Deseja realmente excluir o cupom '" + nome + "'?")) return;
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        fetch('/Cupom/Delete/' + id, { method: 'POST', headers: { 'RequestVerificationToken': token } })
            .then(response => { if (response.ok) location.reload(); else alert("Erro ao excluir."); });
    }
    
    // Script para desaparecer a mensagem automaticamente
    setTimeout(function () {
        var alert = document.querySelector('.alert-custom');
        if (alert) {
            alert.style.transition = "opacity 0.5s ease";
            alert.style.opacity = "0";
            setTimeout(function () { alert.style.display = 'none'; }, 500);
        }
    }, 4000); // A mensagem desaparece após 4 segundos

  
</script>