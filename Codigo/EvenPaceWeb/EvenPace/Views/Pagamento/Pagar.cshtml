@using EvenPaceWeb
@using EvenPaceWeb.Models
@model EvenPaceWeb.Models.PagamentoViewModel
@{
    Layout = null;
    var valorFormatado = Model.ValorKit.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"));
    var valorInvariant = Model.ValorKit.ToString(System.Globalization.CultureInfo.InvariantCulture);
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pagamento – @Model.NomeEvento</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800&display=swap" rel="stylesheet" />

    <style>
        :root {
            --surface: #ffffff;
            --surface-soft: #fffdf3;
            --text: #121212;
            --muted: #6f7780;
            --border: #ece7d5;
            --yellow: #ffe07a;
            --yellow-strong: #f4c542;
            --shadow: 0 18px 40px rgba(18,18,18,.08);
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: "Montserrat", system-ui, sans-serif;
            color: var(--text);
            background: linear-gradient(180deg,#ffffff 0%,#fffef7 100%);
            min-height: 100vh;
        }

        .topbar {
            padding: 18px 18px 14px;
            border-bottom: 1px solid var(--border);
            background: rgba(255,255,255,.95);
            backdrop-filter: blur(10px);
            position: sticky;
            top: 0;
            z-index: 5;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            color: var(--text);
            font-weight: 800;
        }

        .page-title {
            font-size: 1.6rem;
            font-weight: 800;
            letter-spacing: -.03em;
            margin: 0 0 4px;
        }

        .page-subtitle {
            color: var(--muted);
            margin: 0 0 24px;
            font-size: .93rem;
        }

        .summary-card {
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 26px;
            box-shadow: var(--shadow);
            padding: 20px;
            margin-bottom: 20px;
        }

        .summary-title {
            font-size: 1.15rem;
            font-weight: 800;
            margin: 0 0 14px;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 7px 0;
            border-bottom: 1px solid var(--border);
            font-size: .9rem;
        }

            .summary-row:last-child {
                border-bottom: none;
            }

            .summary-row .label {
                color: var(--muted);
            }

            .summary-row .value {
                font-weight: 700;
            }

        .total-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 14px;
            padding-top: 14px;
            border-top: 2px solid var(--border);
        }

        .total-label {
            font-size: 1rem;
            font-weight: 800;
        }

        .total-value {
            font-size: 1.5rem;
            font-weight: 800;
            color: #1a7a3e;
        }

        .brick-card {
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 26px;
            box-shadow: var(--shadow);
            padding: 20px;
        }

        .brick-title {
            font-size: 1.05rem;
            font-weight: 800;
            margin: 0 0 16px;
        }

        .alert-erro {
            display: none;
            background: #fff5f5;
            border: 1px solid #fca5a5;
            border-radius: 14px;
            color: #dc2626;
            padding: 12px 16px;
            margin-top: 14px;
            font-size: .9rem;
            font-weight: 600;
        }
    </style>
</head>
<body>

    <div class="topbar">
        <div class="container-fluid px-0">
            <a href="javascript:history.back()" class="back-link">← Voltar</a>
        </div>
    </div>

    <div class="container-fluid px-3 px-md-4 px-xl-5 py-4" style="max-width:700px;">

        <h1 class="page-title">Finalizar Pagamento</h1>
        <p class="page-subtitle">Preencha os dados do cartão para confirmar sua inscrição.</p>

        @* Resumo da inscrição *@
        <div class="summary-card">
            <div class="summary-title">@Model.NomeEvento</div>

            <div class="summary-row">
                <span class="label">Corredor</span>
                <span class="value">@Model.NomeCorredor</span>
            </div>
            <div class="summary-row">
                <span class="label">Kit</span>
                <span class="value">@(Model.NomeKit ?? "Sem kit")</span>
            </div>
            <div class="summary-row">
                <span class="label">Distância</span>
                <span class="value">@Model.Distancia</span>
            </div>
            <div class="summary-row">
                <span class="label">Tamanho da camisa</span>
                <span class="value">@Model.TamanhoCamisa</span>
            </div>

            <div class="total-row">
                <span class="total-label">Total</span>
                <span class="total-value">R$ @valorFormatado</span>
            </div>
        </div>
        
        @*Brick do Mercado Pago*@ 
        <div class="brick-card">
            <div class="brick-title">💳 Dados do Cartão</div>
            <div id="cardPaymentBrick_container"></div>
            <div id="mp-erro" class="alert-erro"></div>
        </div>

    </div>

    <script src="https://sdk.mercadopago.com/js/v2"></script>
    <script>
        const MP_PUBLIC_KEY = "@Model.MercadoPagoPublicKey";
        const ID_INSCRICAO  = @Model.IdInscricao;
        const VALOR_KIT     = @valorInvariant;

        const mp            = new MercadoPago(MP_PUBLIC_KEY, { locale: "pt-BR" });
        const bricksBuilder = mp.bricks();

        async function renderBrick(builder) {
            const settings = {
                initialization: {
                    amount: VALOR_KIT
                },
                customization: {
                    paymentMethods: {
                        maxInstallments: 3
                    },
                    visual: {
                        style: { theme: "default" }
                    }
                },
                callbacks: {
                    onReady: () => {},

                    onSubmit: (formData) => {
                        return new Promise((resolve, reject) => {

                            // Adiciona o id da inscrição ao payload
                            formData.idInscricao = ID_INSCRICAO;

                            fetch("/Pagamento/Processar", {
                                method : "POST",
                                headers: { "Content-Type": "application/json" },
                                body   : JSON.stringify(formData)
                            })
                            .then(r => r.json())
                            .then(response => {
                                if (response.success) {
                                    window.location.href =
                                        `/Pagamento/Resultado?status=${response.status}` +
                                        `&idTransacaoMP=${response.idTransacaoMP ?? ""}`;
                                    resolve();
                                } else {
                                    const erroDiv = document.getElementById("mp-erro");
                                    erroDiv.textContent = response.mensagemErro
                                        ?? "Pagamento recusado. Verifique os dados do cartão.";
                                    erroDiv.style.display = "block";
                                    reject();
                                }
                            })
                            .catch(() => {
                                const erroDiv = document.getElementById("mp-erro");
                                erroDiv.textContent = "Erro de conexão. Tente novamente.";
                                erroDiv.style.display = "block";
                                reject();
                            });
                        });
                    },

                    onError: (error) => {
                        console.error("Erro no Brick:", error);
                    }
                }
            };

            window.cardPaymentBrickController = await builder.create(
                "cardPayment",
                "cardPaymentBrick_container",
                settings
            );
        }

        renderBrick(bricksBuilder);
    </script>
</body>
</html>