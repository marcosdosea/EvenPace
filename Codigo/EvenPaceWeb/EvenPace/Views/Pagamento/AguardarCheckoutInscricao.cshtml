@model EvenPaceWeb.Models.CheckoutInscricaoViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Aguardando pagamento</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        body {
            min-height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
            font-family: "Montserrat", system-ui, sans-serif;
            background: linear-gradient(180deg, #ffffff 0%, #fffef7 100%);
            color: #121212;
        }

        .checkout-card {
            width: min(100%, 520px);
            padding: 34px 28px;
            border: 1px solid #ece7d5;
            border-radius: 28px;
            background: #fff;
            box-shadow: 0 18px 40px rgba(18, 18, 18, .08);
            text-align: center;
        }

        .checkout-card h1 {
            margin: 0 0 10px;
            font-size: 1.65rem;
            font-weight: 800;
        }

        .checkout-card p {
            margin: 0;
            color: #6f7780;
            line-height: 1.6;
            font-weight: 600;
        }

        .status-box {
            margin: 22px 0;
            padding: 14px 16px;
            border-radius: 16px;
            background: #fffdf3;
            border: 1px solid #ece7d5;
            color: #4d3a08;
            font-weight: 800;
        }

        .btn-payment {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            min-height: 48px;
            padding: 12px 18px;
            border: 0;
            border-radius: 999px;
            background: linear-gradient(135deg, #ffe07a, #f4c542);
            color: #222;
            font-weight: 800;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <main class="checkout-card">
        <h1>Finalize o pagamento</h1>
        <p>O Mercado Pago foi aberto em uma janela separada. Quando o pagamento for aprovado, esta página será atualizada automaticamente.</p>

        <div id="statusBox" class="status-box">Aguardando confirmação do pagamento...</div>

        <button type="button" class="btn-payment" id="abrirCheckout">
            Abrir Mercado Pago
        </button>
    </main>

    <script>
        const checkoutUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CheckoutUrl));
        const statusUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.StatusUrl));
        const resultadoUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ResultadoUrl));
        const statusBox = document.getElementById('statusBox');
        const abrirCheckout = document.getElementById('abrirCheckout');
        let checkoutWindow = null;
        let statusTimer = null;

        function abrirPopup() {
            checkoutWindow = window.open(checkoutUrl, 'evenpaceMercadoPago', 'width=980,height=760');

            if (!checkoutWindow) {
                statusBox.textContent = 'O navegador bloqueou a janela. Clique em "Abrir Mercado Pago".';
                return;
            }

            checkoutWindow.focus();
            statusBox.textContent = 'Checkout aberto. Aguardando confirmação do pagamento...';
            iniciarVerificacao();
        }

        function iniciarVerificacao() {
            verificarStatus();

            if (!statusTimer) {
                statusTimer = setInterval(verificarStatus, 3000);
            }
        }

        async function verificarStatus() {
            try {
                const response = await fetch(statusUrl, { credentials: 'same-origin' });

                if (!response.ok) {
                    statusBox.textContent = 'Ainda não foi possível confirmar o pagamento. Tentando novamente...';
                    return;
                }

                const data = await response.json();
                if (data.confirmada) {
                    statusBox.textContent = 'Pagamento confirmado. Redirecionando...';

                    if (checkoutWindow && !checkoutWindow.closed) {
                        checkoutWindow.close();
                    }

                    window.location.href = resultadoUrl;
                    return;
                }

                if (data.mensagemErro) {
                    statusBox.textContent = data.mensagemErro;
                }
            } catch {
                statusBox.textContent = 'Ainda não foi possível consultar o pagamento. Tentando novamente...';
            }
        }

        abrirCheckout.addEventListener('click', abrirPopup);
    </script>
</body>
</html>
