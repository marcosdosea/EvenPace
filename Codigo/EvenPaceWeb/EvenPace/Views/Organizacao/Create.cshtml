@model Models.OrganizacaoViewModel

@{
    ViewData["Title"] = "Cadastre-se";
}

<style>
    body {
        background-color: #f4f6f9;
        color: #212529;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .cadastro-section {
        min-height: 100vh;
    }

    .evenpace-card {
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 1.5rem;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.06) !important;
    }

    .evenpace-text-yellow {
        color: #d4a017 !important;
    }

    .form-label {
        font-weight: 600;
        color: #475569;
        margin-bottom: 6px;
        font-size: 0.9rem;
    }

    .custom-input {
        border: 1px solid #cbd5e1 !important;
        border-radius: 0.75rem !important;
        padding: 10px 14px;
        width: 100%;
        background-color: #ffffff;
        color: #212529;
        font-weight: 500;
        transition: all 0.2s ease;
    }

        .custom-input:focus {
            outline: none;
            border-color: #ffc107 !important;
            box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.2) !important;
        }

    .btn-check:checked + .btn-outline-warning {
        background-color: #ffc107 !important;
        border-color: #ffc107 !important;
        color: #000000 !important;
        font-weight: 600;
    }

    .btn-outline-warning {
        border-color: #cbd5e1;
        color: #475569;
        border-radius: 0.5rem;
    }

    .btn-save {
        background-color: #ffc107;
        color: #000000;
        border: none;
        border-radius: 50px;
        padding: 12px 40px;
        font-weight: 700;
        transition: all 0.3s ease;
    }

        .btn-save:hover {
            background-color: #ffca2c;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(255, 193, 7, 0.3);
        }

    .btn-back {
        background-color: #ffffff;
        color: #64748b;
        border: 1px solid #cbd5e1;
        border-radius: 50px;
        padding: 12px 35px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-back:hover {
            background-color: #f8fafc;
            color: #334155;
        }
</style>

<section class="cadastro-section d-flex align-items-center py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-xl-10">

                <div class="card evenpace-card p-3 p-md-4">
                    <div class="card-body">

                        <header class="mb-4">
                            <h2 class="fw-bold text-dark m-0">
                                Cadastrar <span class="evenpace-text-yellow">Organização</span>
                            </h2>
                            <p class="text-muted small mt-1">Preencha as informações cadastrais e defina seus dados de login</p>
                        </header>

                        <form asp-action="Create" method="post" data-viacep-form>
                            @Html.AntiForgeryToken()

                            <div asp-validation-summary="ModelOnly" class="alert alert-danger small p-2 mb-4" role="alert"></div>

                            <div class="row g-3">

                                <!-- Nome Completo -->
                                <div class="col-12 col-md-6">
                                    <label asp-for="Nome" class="form-label">Nome Completo / Razão Social</label>
                                    <input asp-for="Nome" class="form-control custom-input" placeholder="Ex: Corrida Eventos LTDA" required />
                                    <span asp-validation-for="Nome" class="text-danger small"></span>
                                </div>

                                <!-- Seletor de Tipo de Documento -->
                                <div class="col-12 col-md-6">
                                    <label class="form-label d-block">Tipo de Organização</label>
                                    <div class="btn-group w-100" role="group">
                                        <input type="radio" class="btn-check" name="tipoDocumento" id="tipoCpf" value="CPF" checked autocomplete="off">
                                        <label class="btn btn-outline-warning py-2" for="tipoCpf">Pessoa Física (CPF)</label>

                                        <input type="radio" class="btn-check" name="tipoDocumento" id="tipoCnpj" value="CNPJ" autocomplete="off">
                                        <label class="btn btn-outline-warning py-2" for="tipoCnpj">Pessoa Jurídica (CNPJ)</label>
                                    </div>
                                </div>

                                <!-- CPF -->
                                <div class="col-12 col-md-6" id="wrapper-cpf">
                                    <label asp-for="Cpf" class="form-label">CPF do Organizador</label>
                                    <input asp-for="Cpf" class="form-control custom-input" placeholder="000.000.000-00" id="input-cpf" />
                                    <span asp-validation-for="Cpf" class="text-danger small"></span>
                                </div>

                                <!-- CNPJ -->
                                <div class="col-12 col-md-6 d-none" id="wrapper-cnpj">
                                    <label asp-for="Cnpj" class="form-label">CNPJ da Empresa</label>
                                    <input asp-for="Cnpj" class="form-control custom-input" placeholder="00.000.000/0001-00" id="input-cnpj" />
                                    <span asp-validation-for="Cnpj" class="text-danger small"></span>
                                </div>

                                <!-- Telefone -->
                                <div class="col-12 col-md-6">
                                    <label asp-for="Telefone" class="form-label">Telefone de Contato</label>
                                    <input asp-for="Telefone" type="tel" class="form-control custom-input" placeholder="(00) 00000-0000" required />
                                    <span asp-validation-for="Telefone" class="text-danger small"></span>
                                </div>

                                <!-- INCLUSÃO DO CAMPO: E-mail -->
                                <div class="col-12 col-md-6">
                                    <label asp-for="Email" class="form-label">E-mail de Acesso (Identity)</label>
                                    <input asp-for="Email" type="email" class="form-control custom-input" placeholder="exemplo@email.com" required />
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>

                                <!-- Senha de Acesso -->
                                <div class="col-12 col-md-6">
                                    <label asp-for="Senha" class="form-label">Senha de Acesso</label>
                                    <input asp-for="Senha" class="form-control custom-input" placeholder="Mínimo 6 caracteres" required />
                                    <span asp-validation-for="Senha" class="text-danger small"></span>
                                </div>

                                <hr class="border-light-subtle my-3">

                                <!-- CEP -->
                                <div class="col-12 col-md-4 col-lg-3">
                                    <label asp-for="Cep" class="form-label">CEP</label>
                                    <input asp-for="Cep" class="form-control custom-input" placeholder="00000-000" inputmode="numeric" required data-viacep-cep />
                                    <span asp-validation-for="Cep" class="text-danger small"></span>
                                </div>

                                <!-- Rua -->
                                <div class="col-12 col-md-8 col-lg-9">
                                    <label asp-for="Rua" class="form-label">Logradouro (Rua/Avenida)</label>
                                    <input asp-for="Rua" class="form-control custom-input" placeholder="Ex: Av. Central" required data-viacep-rua />
                                    <span asp-validation-for="Rua" class="text-danger small"></span>
                                </div>

                                <!-- Bairro -->
                                <div class="col-12 col-md-5">
                                    <label asp-for="Bairro" class="form-label">Bairro</label>
                                    <input asp-for="Bairro" class="form-control custom-input" placeholder="Ex: Centro" required data-viacep-bairro />
                                    <span asp-validation-for="Bairro" class="text-danger small"></span>
                                </div>

                                <!-- Cidade -->
                                <div class="col-12 col-md-5">
                                    <label asp-for="Cidade" class="form-label">Cidade</label>
                                    <input asp-for="Cidade" class="form-control custom-input" placeholder="Ex: Itabaiana" required readonly data-viacep-cidade />
                                    <span asp-validation-for="Cidade" class="text-danger small"></span>
                                </div>

                                <!-- Número -->
                                <div class="col-6 col-md-2">
                                    <label asp-for="Numero" class="form-label">Número</label>
                                    <input asp-for="Numero" type="number" class="form-control custom-input" min="0" oninput="this.value = Math.abs(this.value)" required />
                                    <span asp-validation-for="Numero" class="text-danger small"></span>
                                </div>

                                <!-- Estado -->
                                <div class="col-6 col-md-2 col-lg-2">
                                    <label asp-for="Estado" class="form-label">UF</label>
                                    <input asp-for="Estado" class="form-control custom-input" placeholder="SE" maxlength="2" required readonly data-viacep-estado />
                                    <span asp-validation-for="Estado" class="text-danger small"></span>
                                </div>

                                <input type="hidden" asp-for="StatusSituacao" value="true" />

                                <!-- Botões de Ação -->
                                <div class="col-12 d-flex flex-column flex-sm-row justify-content-end gap-3 mt-4">
                                    <a asp-action="Login" class="btn-back text-center order-2 order-sm-1">Cancelar</a>
                                    <button type="submit" class="btn-save order-1 order-sm-2">Cadastrar Organização</button>
                                </div>
                            </div>
                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="~/js/viacep.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const radCpf = document.getElementById("tipoCpf");
            const radCnpj = document.getElementById("tipoCnpj");
            const wrapperCpf = document.getElementById("wrapper-cpf");
            const wrapperCnpj = document.getElementById("wrapper-cnpj");
            const inputCpf = document.getElementById("input-cpf");
            const inputCnpj = document.getElementById("input-cnpj");

            function alternarCampos() {
                if (radCpf.checked) {
                    wrapperCpf.classList.remove("d-none");
                    wrapperCnpj.classList.add("d-none");
                    inputCpf.setAttribute("required", "required");
                    inputCnpj.removeAttribute("required");
                    inputCnpj.value = "";
                } else if (radCnpj.checked) {
                    wrapperCnpj.classList.remove("d-none");
                    wrapperCpf.classList.add("d-none");
                    inputCnpj.setAttribute("required", "required");
                    inputCpf.removeAttribute("required");
                    inputCpf.value = "";
                }
            }

            radCpf.addEventListener("change", alternarCampos);
            radCnpj.addEventListener("change", alternarCampos);

            alternarCampos();
        });
    </script>
}
